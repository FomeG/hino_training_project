<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="email_template_next_approver_notification" model="mail.template">
            <field name="name">Training Need: Next Approver Notification</field>
            <field name="model_id" ref="model_hmv_training_need"/>
            <field name="subject">Training Need Approval Required: ${object.name}</field>
            <field name="email_from">${object.company_id.email or user.email|safe}</field>
            <field name="email_to">${object.approval_line_ids.filtered(lambda l: l.status == 'waiting')[0].employee_id.work_email|safe}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear ${object.approval_line_ids.filtered(lambda l: l.status == 'waiting')[0].employee_id.name},
                        <br/><br/>
                        You have a pending approval for Training Need: ${object.name}.
                        <br/><br/>
                        Please review and take necessary action.
                        <br/><br/>
                        Best regards,<br/>
                        ${object.company_id.name}
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>