<odoo>
    <data>
        <template id="factory_training_report_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="doc">
                        <!-- Header Section -->
                        <div class="page" data-oe-model="hmv.training.plan" t-att-data-oe-id="doc.id">
                            <div class="row mb-4">
                                <div class="col-3">
                                    <img src="/hmv_training/static/description/hino_logo.png" style="max-height: 50px;"/>
                                </div>
                                <div class="col-6 text-center">
                                    <h3>SUMMARY OF TRAINING PLAN FY2023</h3>
                                </div>
                                <div class="col-3 text-right">
                                    <p>Mã số/No: <t t-esc="doc.name"/></p>
                                    <p>Ngày ban hành/Issue date: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/></p>
                                </div>
                            </div>

                            <!-- Training courses information by office Section -->
                            <div style="background-color: #FFFFCC; border: 1px solid black; padding: 5px; margin-bottom: 10px;">
                                <p style="text-align: center; font-weight: bold; margin: 0;">Training courses information by office</p>
                            </div>

                            <!-- First Table - Training Courses by Department -->
                            <table class="table table-bordered" style="margin-bottom: 20px;">
                                <thead>
                                    <tr style="background-color: #D3D3D3;">
                                        <th style="width: 5%; text-align: center; vertical-align: middle;">TT No</th>
                                        <th style="width: 20%; text-align: center; vertical-align: middle;">Phòng ban<br/>Dept</th>
                                        <th style="width: 10%; text-align: center; vertical-align: middle;"></th>
                                        <th colspan="8" style="text-align: center; vertical-align: middle;">Name of training courses</th>

                                    </tr>
                                    <tr style="background-color: #D3D3D3;">
                                        <td colspan="3"></td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                        <td style="text-align: center;">Name of training course </td>
                                    </tr>
                                    <tr style="background-color: #D3D3D3;">
                                        <td colspan="3"></td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                        <td style="text-align: center;">Date</td>
                                    </tr>
                                    <tr style="background-color: #D3D3D3;">
                                        <td colspan="3"></td>
                                        <td style="text-align: center;">Name of Supplier </td>
                                        <td style="text-align: center;">Name of Supplier</td>
                                        <td style="text-align: center;">Name of Supplier</td>
                                        <td style="text-align: center;">Name of Supplier</td>
                                        <td style="text-align: center;">Name of Supplier</td>
                                        <td style="text-align: center;">Name of Supplierr</td>
                                        <td style="text-align: center;">Name of Supplier</td>
                                        <td style="text-align: center;">Name of Supplier</td>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Section 1. Các khóa học tập trung lập kế hoạch hàng năm: Training courses provided by Company (job-refer to Training Brochure FY2023) -->
                                    <tr>
                                        <td colspan="11" style="font-weight: bold;">1. Các khóa học tập trung lập kế hoạch hàng năm: Training courses provided by Company (job-refer to Training Brochure FY2023)</td>
                                    </tr>
                                    <tr>
                                        <td style="text-align: center;">1</td>
                                        <td>General Administration Dept</td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align: center;">2</td>
                                        <td>Human Resource Dept</td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align: center;">3</td>
                                        <td>Purchasing, Import &amp; Export Dept</td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                    <!-- Add more departments as needed -->
                                    <tr>
                                        <td colspan="2" style="text-align: center; font-weight: bold;">Quantity/Course</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="text-align: center; font-weight: bold;">Training fee</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                        <td style="text-align: center;">0</td>
                                    </tr>
                                    <tr>
                                        <td colspan="11" style="font-weight: bold;">Other fee (material, venue, transportation...)</td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="text-align: center; font-weight: bold; background-color: #c7d7eb;">Sub Total Estimated Training Fee for Office (1)</td>
                                        <td colspan="9" style="text-align: right; font-weight: bold; background-color: #c7d7eb;">
                                            <t t-set="total_fee" t-value="sum(course.estimated_fee for course in doc.tab_training_courses_id)"/>
                                            <t t-esc="total_fee"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Second Table - Factory Training -->
                            <div style="page-break-before: always;"></div>
                            <div style="margin-top: 20px;">
                                <p style="font-weight: bold;">2. Các khóa học tập trung theo năm tài chính trong năm</p>
                                <table class="table table-bordered">
                                    <thead>
                                        <tr style="background-color: #D3D3D3;">
                                            <th style="width: 5%; text-align: center;">TT No</th>
                                            <th style="width: 25%; text-align: center;">Khóa học<br/>Training course</th>
                                            <th style="width: 20%; text-align: center;">Đơn vị đào tạo<br/>Supplier</th>
                                            <th style="width: 25%; text-align: center;">Thời gian đào tạo<br/>Training time</th>
                                            <th style="width: 25%; text-align: center;">Chi phí dự kiến<br/>Estimated fee</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.tab_factory_id" t-as="course" t-foreach-index="index">
                                            <tr>
                                                <td style="text-align: center;"><t t-esc="(index or 0) + 1"/></td>
                                                <td><t t-esc="course.course_title"/></td>
                                                <td><t t-esc="course.vendor_id.name"/></td>
                                                <td style="text-align: center;"><t t-esc="course.start_date"/></td>
                                                <td style="text-align: right;"><t t-esc="course.estimated_fee"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <table style="width:100%; margin-top:10px; background-color: #c7d7eb;" border="1">
                                    <tr>
                                        <td style="text-align:left; font-weight:bold; padding:5px;">
                                            Estimated Training Fee for Factory (2)
                                        </td>
                                        <td style="text-align:right; font-weight:bold; padding:5px;">
                                            <!-- <t t-set="total_factory_fee" t-value="sum(course.estimated_fee for course in doc.tab_factory_id)"/> -->
                                            <t t-esc="total_fee_tab_factory"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Third Table - Others Training -->
                            <div style="margin-top: 20px;">
                                <p style="font-weight: bold;">3. Các khóa học theo từng khoa (các khóa học bổ sung của từng phòng ban khác) - Others (Based on the specific need of departments)</p>
                                <table class="table table-bordered">
                                    <thead>
                                        <tr style="background-color: #D3D3D3;">
                                            <th style="width: 5%; text-align: center;">TT No</th>
                                            <th style="width: 15%; text-align: center;">Phòng ban<br/>Dept</th>
                                            <th style="width: 20%; text-align: center;">Khóa học<br/>Training course</th>
                                            <th style="width: 15%; text-align: center;">Đơn vị đào tạo<br/>Supplier</th>
                                            <th style="width: 15%; text-align: center;">Thời gian đào tạo<br/>Training time</th>
                                            <th style="width: 15%; text-align: center;">Chi phí dự kiến<br/>Estimated fee</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.tab_others_id" t-as="course" t-foreach-index="index">
                                            <tr>
                                                <td style="text-align: center;"><t t-esc="(index or 0) + 1"/></td>
                                                <td><t t-esc="course.department_id.name"/></td>
                                                <td><t t-esc="course.course_title"/></td>
                                                <td><t t-esc="course.vendor_id.name"/></td>
                                                <td style="text-align: center;"><t t-esc="course.start_date"/></td>
                                                <td style="text-align: right;"><t t-esc="course.estimated_fee"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <table style="width:100%; margin-top:10px; background-color: #c7d7eb;" border="1">
                                    <tr>
                                        <td style="text-align:left; font-weight:bold; padding:5px;">
                                            Other Estimated Training Fee (3)
                                        </td>
                                        <td style="text-align:right; font-weight:bold; padding:5px;">
                                            <!-- <t t-set="total_others_fee" t-value="sum(course.estimated_fee for course in doc.tab_others_id)"/> -->
                                            <t t-esc="total_fee_tab_other"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:left; font-weight:bold; padding:5px;">
                                            Other Total (4)
                                        </td>
                                        <td style="text-align:right; font-weight:bold; padding:5px;">
                                            0
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:left; font-weight:bold; padding:5px;">
                                            Other Training (5)
                                        </td>
                                        <td style="text-align:right; font-weight:bold; padding:5px;">
                                            0
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Final Total Section -->
                            <table style="width:100%; margin-top:20px; background-color: #c7d7eb;" border="1">
                                <tr>
                                    <td style="text-align:left; font-weight:bold; padding:5px;">
                                        TOTAL TRAINING FEE FOR OFFICE (1)+(2)+(3)+(4)+(5)
                                    </td>
                                    <td style="text-align:right; font-weight:bold; padding:5px; width: 30%;">
                                        <t t-set="total_fee" t-value="sum(course.estimated_fee for course in doc.tab_training_courses_id) + sum(course.estimated_fee for course in doc.tab_factory_id) + sum(course.estimated_fee for course in doc.tab_others_id)"/>
                                        <t t-esc="total_fee"/>
                                    </td>
                                    <td style="text-align:right; font-weight:bold; padding:5px; width: 20%;">
                                        Budget compared FY22
                                    </td>
                                </tr>
                            </table>

                            <!-- Signature Section -->
                            <div style="margin-top: 40px; font-size: 12px;">
                                <p>* Remark for fixed reference</p>
                                <p>* Training Provider (will be implemented based on actual situation)</p>
                            </div>

                            <table style="width:100%; margin-top:20px; border: 1px solid black;" border="1">
                                <tr>
                                    <td style="width: 25%; text-align: center; padding: 10px;">
                                        Xác nhận<br/>
                                        Confirmed
                                    </td>
                                    <td style="width: 25%; text-align: center; padding: 10px;">
                                        Kiểm tra<br/>
                                        Checked
                                    </td>
                                    <td style="width: 25%; text-align: center; padding: 10px;">
                                        Trình duyệt<br/>
                                        Submitted
                                    </td>
                                    <td style="width: 25%; text-align: center; padding: 10px;">
                                        Phê duyệt<br/>
                                        Approved
                                    </td>
                                </tr>
                                <tr>
                                    <td style="height: 80px;"></td>
                                    <td style="height: 80px;"></td>
                                    <td style="height: 80px;"></td>
                                    <td style="height: 80px;"></td>
                                </tr>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_report_training_factory" model="ir.actions.report">
            <field name="name">Training Plan Summary Report</field>
            <field name="model">hmv.training.plan</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hino_training.factory_training_report_template</field>
            <field name="report_file">hino_training.factory_training_report_template</field>
            <field name="binding_model_id" ref="model_hmv_training_plan"/>
            <field name="binding_type">report</field>
            <field name="attachment_use">True</field>
            <field name="attachment">('Training_Plan_Summary_' + object.name + '.pdf')</field>
        </record>
    </data>
</odoo>

