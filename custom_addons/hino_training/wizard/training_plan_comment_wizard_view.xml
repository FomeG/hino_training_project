<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_training_plan_comment_wizard" model="ir.ui.view">
        <field name="name">hmv.training.plan.comment.wizard.form</field>
        <field name="model">hmv.training.plan.comment.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Comment">
                <sheet>
                    <group>
                        <field name="comment" placeholder="Enter your comment..." />
                        <field name="action_type"/>
                        <field name="training_plan_id" invisible="1" />
                        <!-- <field name="approval_status" invisible="1" /> -->
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm"
                        string="Confirm"
                        type="object"
                        class="btn-primary" />
                    <button name="action_cancel"
                        string="Cancel"
                        type="object"
                        class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>
</odoo>