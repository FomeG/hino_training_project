<odoo>
  <data>
    <!-- explicit list view definition -->

    <record model="ir.ui.view" id="hino_training.list">
      <field name="name">hino_training list</field>
      <field name="model">hino_training.hino_training</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
        </tree>
      </field>
    </record>

    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="hino_training.action_window">
      <field name="name">hino_training window</field>
      <field name="res_model">hino_training.hino_training</field>
      <field name="view_mode">tree,form</field>
    </record>


    <!-- server action to the one above -->

    <record model="ir.actions.server" id="hino_training.action_server">
      <field name="name">hino_training server</field>
      <field name="model_id" ref="model_hino_training_hino_training"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "tree,form",
          "res_model": model._name,
        }
      </field>
    </record>


    <!-- Top menu item -->

    <menuitem name="hino_training" id="hino_training.menu_root"/>

    <!-- menu categories -->

    <menuitem name="Menu 1" id="hino_training.menu_1" parent="hino_training.menu_root"/>
    <menuitem name="Menu 2" id="hino_training.menu_2" parent="hino_training.menu_root"/>


    <!-- actions -->

    <menuitem name="List" id="hino_training.menu_1_list" parent="hino_training.menu_1"
              action="hino_training.action_window"/>
    <menuitem name="Server to list" id="hino_training.menu_server_to_list" parent="hino_training.menu_2"
          action="hino_training.action_server"/>


  </data>
</odoo>
