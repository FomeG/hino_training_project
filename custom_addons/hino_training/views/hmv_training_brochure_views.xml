<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_hmv_training_brochure_tree" model="ir.ui.view">
        <field name="name">hmv.training.brochure.tree</field>
        <field name="model">hmv.training.brochure</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="year"/>
                <field name="created_on"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="company_id"/>
                <field name="name"/>
            </tree>
        </field>
    </record>
    <!-- Kanban View -->
    <record id="view_hmv_training_brochure_kanban" model="ir.ui.view">
        <field name="name">hmv.training.brochure.kanban</field>
        <field name="model">hmv.training.brochure</field>
        <field name="arch" type="xml">
            <kanban default_group_by="year">
                <field name="year"/>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="employee_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <h3 class="oe_kanban_record_title">
                                    <field name="name"/>
                                </h3>
                                <ul>
                                    <li t-if="record.start_date.raw_value">
                                        <strong>Start Date: </strong><field name="start_date"/>
                                    </li>
                                    <li t-if="record.end_date.raw_value">
                                        <strong>End Date: </strong><field name="end_date"/>
                                    </li>
                                    <li t-if="record.employee_id.raw_value">
                                        <strong>Creator: </strong><field name="employee_id"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Form View -->
    <record id="view_hmv_training_brochure_form" model="ir.ui.view">
        <field name="name">hmv.training.brochure.form</field>
        <field name="model">hmv.training.brochure</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_update_courses" string="Update Course" type="object" class="btn-success"
                            invisible="not is_update_button_visible "/>
                </header>
                <sheet>
                    <h3>Training Brochure No.</h3>
                    <h1>
                        <field name="code" readonly="1"/>
                    </h1>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="year"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="employee_id"/>
                            <field name="company_id"/>
                            <field name="created_on"/>
                            <field name="is_update_button_visible" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                            <!-- Tab 1: Company Courses -->
                        <page string="Training courses provided by company" name="company_training">
                            <field name="company_training_ids" context="{'active_tab': 'company_training'}">
                                <tree editable="bottom">
                                    <field name="course_name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 2: Factory Training -->
                        <page string="Factory Training" name="factory_training">
                            <field name="factory_training_ids" context="{'active_tab': 'factory_training'}">
                                <tree editable="bottom">
                                    <field name="course_name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 3: Other Courses -->
                        <page string="Other" name="other_training" >
                            <field name="other_training_ids" context="{'active_tab': 'other_training'}">
                                <tree editable="bottom">
                                    <field name="course_name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter" position="inside">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hmv_training_brochure_search" model="ir.ui.view">
        <field name="name">hmv.training.brochure.search</field>
        <field name="model">hmv.training.brochure</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="year"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hmv_training_brochure" model="ir.actions.act_window">
        <field name="name">Training Brochures</field>
        <field name="res_model">hmv.training.brochure</field>
        <field name="view_mode">tree,kanban,form</field>
    </record>

</odoo>