<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_hmv_training_courses_form" model="ir.ui.view">
            <field name="name">hmv.training.courses.form</field>
            <field name="model">hmv.training.courses</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit"
                                string="Submit for Approval"
                                type="object"
                                class="oe_highlight"
                                invisible="status != 'draft'"/>
                          <!-- Staff Approval Button -->
                        <button name="action_staff_approve"
                                string="Staff Approve"
                                type="object"
                                class="oe_highlight"
                                groups="base.group_user"
                                invisible="status != 'staff_approval'"/>
                        <button name="action_hr_approve"
                                string="HR Manager Approve"
                                type="object"
                                class="oe_highlight"
                                groups="hr.group_hr_manager"
                                invisible="status != 'hr_approval'"/>
                        <button name="action_fd_approve"
                                string="Finance Director Approve"
                                type="object"
                                class="oe_highlight"
                                invisible="status != 'fd_approval'"/>
                        <button name="action_gd_approve"
                                string="General Director Approve"
                                type="object"
                                class="oe_highlight"
                                invisible="status != 'gd_approval'"/>
                        <button name="action_active"
                                string="Activate"
                                type="object"
                                class="oe_highlight"
                                invisible="not ((status == 'fd_approval' and estimate_fee &lt; 100000000) or status == 'gd_approval')"/>
                        <!-- Rejection Button for All Approvers -->
                        <button name="action_reject"
                                string="Reject"
                                type="object"
                                class="btn-danger"
                                invisible="status not in ('staff_approval', 'hr_approval', 'fd_approval', 'gd_approval')"/>
                        <button name="action_register_course"
                                string="Register Course"
                                type="object"
                                class="oe_highlight"
                                invisible="status != 'active'"/>
                        <button name="action_edit" string="Edit" type="object"
                                invisible="status not in ('draft', 'refused')"/>
                        <button name="action_save" string="Save" type="object"
                                invisible="status != 'draft'"/>
                        <button name="action_start" string="Start" type="object"
                                invisible="status != 'active'"/>
                        <button name="action_done" string="Done" type="object"
                                invisible="status != 'in_progress'"/>
                        <button name="action_cancel" string="Cancel Course" type="object"
                                invisible="status not in ('active', 'in_progress', 'staff_approval',
                                                          'hr_approval', 'fd_approval', 'gd_approval')"/>
                        <field name="status" widget="statusbar"
                               statusbar_visible="draft,staff_approval,hr_approval,fd_approval,gd_approval,active,in_progress,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="course_title" placeholder="Course Title" required="1"/>
                            </h1>
                        </div>
                        <group>
                          <field name="current_approval_level" invisible="1"/>
                            <group>
                                <field name="year"/>
                                <field name="start_date" required="1"/>
                                <field name="end_date" required="1"/>
                                <field name="training_brochure_id" required="1"/>
                                <!--                                  domain="[('training_brochure_id.year', '=', year)]"/> training brochure khong co year-->
                                <field name="purchase_order_id" domain="[('partner_id', '=', vendor_id)]"/>
                                <field name="vendor_id" required="1"
                                       domain="[('is_company', '=', True), ('active', '=', True)]"/>
                                <field name="confirmation_start_date" required="1"/>
                                <field name="confirmation_end_date" required="1"/>
                                <field name="slot" required="1"/>
                                <field name="file_attach" widget="many2many_binary"/>
                            </group>
                            <group>
                                <field name="course_type" required="1"/>
                                <field name="estimate_fee" required="1"/>
                                <field name="department_id" required="1" domain="[('active', '=', True)]"/>
                                <field name="employee_id" widget="many2many_tags" required="1"/>
                                <field name="employee_hr_id"/>
                                <field name="deptcombine"/>
                                <field name="training_method" required="1"/>
                                <field name="location_id" required="1"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="audience_ids" required="0" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group>
                            <field name="training_content" required="1"/>
                            <field name="description" required="1"/>

                        </group>
                        <notebook>
                            <page string="List of participant">
                                <field name="participant_ids">
                                    <tree editable="bottom">
                                        <field name="employee_id" required="1"/>
                                        <field name="full_name" readonly="1"/>
                                        <field name="email" readonly="1"/>
                                        <field name="position" readonly="1"/>
                                        <field name="department" readonly="1"/>
                                        <field name="status" readonly="1"/>
                                        <button name="action_confirm" string="Confirm" type="object"
                                                icon="fa-check" invisible="status != 'waiting'"/>
                                        <button name="action_refuse" string="Refuse" type="object"
                                                icon="fa-times" invisible="status != 'waiting'"/>
                                        <button name="action_resend" string="RESEND" type="object" icon="fa-envelope"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Approval History">
                                <field name="approval_ids">
                                    <tree string="Approvals" create="0" delete="0">
                                        <field name="sequence" widget="handle"/>
                                        <field name="employee_id"/>
                                        <field name="job_id"/>
                                        <field name="department_id"/>
                                        <field name="status"/>
                                        <field name="comment"/>
                                        <field name="date"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_hmv_training_courses_tree" model="ir.ui.view">
            <field name="name">hmv.training.courses.tree</field>
            <field name="model">hmv.training.courses</field>
            <field name="arch" type="xml">
                <tree decoration-info="status=='draft'"
                      decoration-warning="status in ('staff_approval', 'hr_approval', 'fd_approval', 'gd_approval')"
                      decoration-success="status=='active'"
                      decoration-primary="status=='in_progress'"
                      decoration-muted="status=='cancel'">
                    <field name="course_title"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="vendor_id"/>
                    <field name="department_id"/>
                    <field name="course_type"/>
                    <field name="estimate_fee"/>
                    <field name="slot"/>
                    <field name="remaining_slots"/>
                    <field name="status"/>
                    <button name="action_register_course"
                            string="Register Course"
                            type="object"
                            class="btn btn-primary"
                            invisible="not status == 'active'"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_hmv_training_courses_search" model="ir.ui.view">
            <field name="name">hmv.training.courses.search</field>
            <field name="model">hmv.training.courses</field>
            <field name="arch" type="xml">
                <search>
                    <field name="course_title"/>
                    <field name="vendor_id"/>
                    <field name="department_id"/>
                    <field name="training_method"/>
                    <field name="employee_id"/>
                    <separator/>
                    <filter string="Draft" name="filter_draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Active" name="filter_active" domain="[('status', '=', 'active')]"/>
                    <filter string="In Progress" name="filter_in_progress" domain="[('status', '=', 'in_progress')]"/>
                    <filter string="Done" name="filter_done" domain="[('status', '=', 'done')]"/>
                    <filter string="Cancelled" name="filter_cancel" domain="[('status', '=', 'cancel')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Vendor" name="group_vendor_id" context="{'group_by': 'vendor_id'}"/>
                        <filter string="Department" name="group_department_id" context="{'group_by': 'department_id'}"/>
                        <filter string="Course Type" name="group_course_type" context="{'group_by': 'course_type'}"/>
                        <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Calendar View -->
        <record id="view_hmv_training_courses_calendar" model="ir.ui.view">
            <field name="name">hmv.training.courses.calendar</field>
            <field name="model">hmv.training.courses</field>
            <field name="arch" type="xml">
                <calendar date_start="start_date" date_stop="end_date" color="status" mode="month">
                    <field name="course_title"/>
                    <field name="vendor_id"/>
                    <field name="department_id"/>
                    <field name="remaining_slots"/>
                </calendar>
            </field>
        </record>


        <!-- Actions -->
        <record id="action_hmv_training_courses" model="ir.actions.act_window">
            <field name="name">Training Courses</field>
            <field name="res_model">hmv.training.courses</field>
            <field name="view_mode">tree,form,calendar</field>
            <field name="search_view_id" ref="view_hmv_training_courses_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first training course!
                </p>
            </field>
        </record>
    </data>
</odoo>