<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <!-- Tree View: Danh sách Training Plan -->
    <record id="view_training_plan_tree" model="ir.ui.view">
      <field name="name">training.plan.tree</field>
      <field name="model">training.plan</field>
      <field name="arch" type="xml">
        <tree string="Training Plans">
          <field name="name"/>
          <field name="year"/>
          <field name="total"/>
          <field name="training_brochure_id"/>
          <field name="total_training_fee"/>
          <field name="company_id"/>
        </tree>
      </field>
    </record>

    <!-- Form View: Chi tiết Training Plan -->
    <record id="view_training_plan_form" model="ir.ui.view">
      <field name="name">training.plan.form</field>
      <field name="model">training.plan</field>
      <field name="arch" type="xml">
        <form string="Training Plan">
          <header>
            <!-- Nút Edit: chỉ hiển thị khi state là draft hoặc rejected -->
            <button name="action_edit" type="object" string="Edit"
              class="btn-primary"
              attrs="{'invisible': [('state', 'not in', ['draft', 'rejected'])]}"/>
            <!-- Nút Save: chỉ hiển thị khi state là draft -->
            <button name="action_save" type="object" string="Save"
              class="btn-success"
              attrs="{'invisible': [('state', '!=', 'draft')]}"/>
            <!-- Field state được ẩn trên header -->
            <field name="state" invisible="1"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="name" readonly="1"/>
                <field name="year"/>
              </group>
              <group>
                <field name="total"/>
                <field name="training_brochure_id"/>
              </group>
            </group>
            <group>
              <field name="total_training_fee"/>
              <field name="company_id" readonly="1"/>
            </group>
            <notebook>
              <page string="Description">
                <field name="description"/>
              </page>
            </notebook>
          </sheet>
          <footer>
            <!-- Nút Create: mở form tạo mới Training Plan -->
            <button name="action_create_record" type="object" string="Create" class="btn-info"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Action cho Training Plan: kết hợp tree và form view -->
    <record id="action_training_plan" model="ir.actions.act_window">
      <field name="name">Training Plans</field>
      <field name="res_model">training.plan</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu item cho Training Plan -->
    <menuitem id="menu_training_plan_root" name="Training Plans" sequence="10"/>
    <menuitem id="menu_training_plan" name="Training Plans"
      parent="menu_training_plan_root"
      action="action_training_plan" sequence="1"/>
      
  </data>
</odoo>
