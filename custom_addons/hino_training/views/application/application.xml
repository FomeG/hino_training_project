<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_application_for_atc_tree" model="ir.ui.view">
        <field name="name">application.tree</field>
        <field name="model">application</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="x_request_date"/>
                <field name="x_applicant_id"/>
                <field name="x_department_id"/>
                <field name="x_course_title"/>
            </tree>
        </field>
    </record>

    <record id="view_application_for_atc_form" model="ir.ui.view">
        <field name="name">application.form</field>
        <field name="model">application</field>
        <field name="arch" type="xml">
            <form>
                <!--                <div>-->
                <!--                    <button name="action_button_edit" type="object" string="Edit"-->
                <!--                            class="me-2 oe_stat_button border-2 border-primary bg-light text-primary"-->
                <!--                            icon="fa-gear"-->
                <!--                            invisible="0">-->
                <!--                                                <field name="appointment_count" widget="statinfo" string=" Appointments"/>-->
                <!--                    </button>-->

                <!--                    <button name="action_button_save" type="object" string="Save"-->
                <!--                            class="me-2 oe_stat_button border-2 border-success bg-light text-success"-->
                <!--                            icon="fa-file-text-o"-->
                <!--                            invisible="0">-->
                <!--                                                <field name="repair_order_count" widget="statinfo" string=" Orders"/>-->
                <!--                    </button>-->
                <!--                </div>-->

                <title>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_button_edit" type="object" icon="fa-pencil"
                                invisible="0"
                                string="Edit"
                                class="me-2 oe_stat_button border-2 border-info bg-light text-info"/>
                        <button name="action_button_save" type="object" icon="fa-save"
                                invisible="0"
                                string="Save"
                                class="me-2 oe_stat_button border-2 border-info bg-light text-info"/>
                    </div>
                </title>

                <header>
                    <field name="x_approval_status" widget="statusbar"/>

                    <button name="action_button_approve" type="object"
                            invisible="0"
                            string="Approve"
                            class="me-2 btn-success oe_highlight"/>
                    <button name="action_button_refuse" type="object"
                            invisible="0"
                            string="Refuse"
                            class="me-2 btn-danger oe_highlight"/>

                    <button name="action_button_set_waiting" type="object"
                            invisible="x_approval_status == 'wait'"
                            string="Set to Waiting"
                            class="me-2 btn-secondary oe_highlight"/>
                </header>

                <sheet>
                    <h3>Application No.</h3>
                    <h1>
                        <field name="name" readonly="1" placeholder=""/>
                    </h1>

                    <group>
                        <group>
                            <field name="x_applicant_id"/>
                            <field name="x_department_id"/>
                            <field name="x_position_id"/>
                        </group>

                        <group>
                            <field name="x_request_date"/>
                        </group>
                    </group>

                    <group string="Training course information">
                        <group>
                            <field name="x_course_title"/>
                            <field name="x_start_date"/>
                            <field name="x_end_date"/>
                            <field name="x_vendor_id"/>
                            <field name="x_staff_id"/>
                            <field name="x_slots"/>
                            <field name="x_remaining_slots"/>
                            <field name="x_training_content"/>
                        </group>

                        <group>
                            <field name="x_purpose_training"/>
                            <field name="x_start_date_confirm"/>
                            <field name="x_end_date_confirm"/>
                            <field name="x_department_apply_id"/>
                            <field name="x_training_plan_id"/>
                            <field name="x_training_method"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Approval History">
                            <group>
                                <group editable="bottom">
                                    <field name="x_approval_employee_id"/>
                                    <field name="x_approval_job_id"/>
                                    <field name="x_approval_department_id"/>
                                    <field name="x_approval_status" widget="badge"
                                           decoration_info="x_approval_status == 'wait'"
                                           decoration_success="x_approval_status == 'approved'"
                                           decoration_warning="x_approval_status == 'refused'"/>
                                    <field name="x_approval_comment"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_application_for_atc_list" model="ir.actions.act_window">
        <field name="name">Application for Attending Courses</field>
        <field name="res_model">application</field>
        <field name="view_mode">tree,form</field>
    </record>


</odoo>