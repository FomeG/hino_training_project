<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <!-- Tree View: Danh sách Training Plan -->
    <record id="view_training_plan_tree" model="ir.ui.view">
      <field name="name">training.plan.tree</field>
      <field name="model">hmv.training.plan</field>
      <field name="arch" type="xml">
        <tree string="Training Plans">
          <field name="name"/>
          <field name="year"/>
          <field name="total"/>
          <field name="training_brochure_id"/>
          <field name="total_training_fee"/>
          <field name="company_id"/>
              <field name="state" string="State"
                 decoration-warning="state == 'approved'" 
                   decoration-info="state == 'fd_processing'"
                />
        </tree>
      </field>
    </record>

  <!-- Form View: Chi tiết Training Plan -->
<record id="view_training_plan_form" model="ir.ui.view">
    <field name="name">training.plan.form</field>
    <field name="model">hmv.training.plan</field>
    <field name="arch" type="xml">
        <form string="Training Plan">
            <header>
                <button name="action_send_approval" type="object" string="Submit for Approval" class="btn-primary"/>
                <button name="action_cancel" type="object" class="oe_stat_button border-2 border-warning bg-light text-warning" icon="fa-user-circle">
                    <span>Cancel</span>
                </button>
                <button name="action_Hr_Manager_Processing" type="object" class="oe_stat_button border-2 border-success bg-light text-success" icon="fa-file-text-o">
                    <span>HR Manager Processing</span>
                </button>
                <field name="state" widget="statusbar" statusbar_visible="draft,fd_processing,hr_manager_processing,approved,cancel"/>
            </header>
            
            <sheet>
                <group>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="year" required="1"/>
                    </group>
                    <group>
                        <field name="total"/>
                        <field name="training_brochure_id"/>
                        <field name="description" widget="text" placeholder="Enter training description..."/>

                    </group>
                </group>
                
                <group>
                    <field name="total_training_fee"/>
                    <field name="company_id" readonly="1"/>
                </group>

                  <notebook>
                      <!-- <page string="Training Courses" name="training_courses">
                          <field name="description" widget="text" placeholder="Enter training description..."/>
                      </page> -->
                  </notebook>
                  
                  
            </sheet>
              <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
            <footer>
                <button name="action_create_record" type="object" string="Create" class="btn-info"/>
            </footer>
        </form>
    </field>
</record>

<!-- Inherit tab approval -->

        <!-- Inherit view_training_plan_form -->
        <record id="view_tab_aprroval_history_inherit2_tab_approval" model="ir.ui.view">
            <field name="name">training.course.form.inherit.tab.approval</field>
            <field name="model">hmv.training.plan</field>
            <field name="inherit_id" ref="hino_training.view_training_plan_form"/>
            <field name="arch" type="xml">
                <!-- Chèn tab mới vào trong notebook -->
            <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Approval history" name="tab_approval_history">
                            <field name="training_plan_line">
                                <tree editable="bottom">
                                    <field name="course_title"/>
                                    <field name="vendor_id"/>
                                    <field name="location_id"/>
                                    <field name="slot"/>
                                    <field name="recommend_level_ids"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="course_type"/>
                                    <field name="fee"/>
                                    <field name="estimated_fee"/>
                                    <field name="other_fee"/>
                                    <field name="participant_ids"/>
                                    <field name="department_id"/>
                                    <field name="purchase_order_id"/>


                                    
                                    <field name="department_id"/>
                                    <field name="location_id"/>
                                    <field name="department_id"/>
                                    <field name="currency_id"/>


                                    <field name="training_content"/>
                                    <field name="confirmation_start_date"/>
                                    <field name="confirmation_end_date"/>
                                    <field name="year"/>


                                    <field name="description"/>
                                    <field name="status"/>
                                    <field name="department_id"/>
                                    <field name="currency_id"/>  
                                    <field name="department_id"/>
                                    <field name="currency_id"/>



                                </tree>
                            </field>
                    </page>
                </xpath>
            </field>
        </record>

