<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <!-- Tree View: Danh sách Training Plan -->
    <record id="view_training_plan_tree" model="ir.ui.view">
      <field name="name">training.plan.tree</field>
      <field name="model">hmv.training.plan</field>
      <field name="arch" type="xml">
        <tree string="Training Plans">
          <field name="name"/>
          <field name="year"/>
          <field name="total"/>
          <field name="training_brochure_id"/>
          <field name="total_training_fee"/>
          <field name="company_id"/>
        <field name="state" string="State" widget="badge"
            decoration-success="state == 'approved'" 
            decoration-info="state == 'draft'"
            decoration-danger="state == 'fd_processing'"
        />

        </tree>
      </field>
    </record>

  <!-- Form View: Chi tiết Training Plan -->
<record id="view_training_plan_form" model="ir.ui.view">
    <field name="name">training.plan.form</field>
    <field name="model">hmv.training.plan</field>
    <field name="arch" type="xml">
        <form string="Training Plan">
            <header>
             <!-- Nút Submit -->
             <!-- Nút Submit for Approval -->
                <button name="action_submit"
                        string="Submit for Approval"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft'"/>

                <!-- Nút HR Manager Approve -->
                <button name="action_send_approval"
                        string="HR Manager Approve"
                        type="object"
                        class="oe_highlight"
                        groups="hr.group_hr_manager"
                        invisible="state != 'hr_manager_processing'"/>

                <!-- Nút Finance Director Approve -->
                <button name="action_fd_processing"
                        string="Finance Director Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'fd_processing'"/>

                <!-- Nút General Director Approve -->
                <button name="create_approval_record"
                        string="General Director Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'approved'"/>

                <!-- Nút Reject -->
                <button name="action_cancel"
                        string="Reject"
                        type="object"
                        class="btn-danger"
                        modifiers="{'invisible': [('state', 'not in', ['hr_manager_processing', 'fd_processing', 'approved'])]}"/>
                <button name="action_print_training_courses"
                    string="Print (PDF)"
                    type="object"
                    class="btn-primary"/>

                <!-- <button name="action_print_training_courses_detail"
                    string="Print Detail (PDF)"
                    type="object"
                    class="btn-secondary"/> -->

                <field name="state" widget="statusbar" statusbar_visible="draft,hr_manager_processing,fd_processing,approved,cancel"/>
            </header>
            
            <sheet>
                <group>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="year" required="1"/>
                    </group>
                    <group>
                        <field name="total"/>
                        <field name="training_brochure_id"/>
                        <field name="description" widget="text" placeholder="Enter training description..."/>

                    </group>
                </group>
                
                <group>
                    <field name="total_training_fee"/>
                    <field name="company_id" readonly="1"/>
                </group>

                  <notebook>
       
                  </notebook>
                  
                  
            </sheet>
              <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
            <footer>
                <button name="action_create_record" type="object" string="Create" class="btn-info"/>
            </footer>
        </form>
    </field>
</record>
         <!-- Inherit view_training_plan_form -->
<record id="view_training_course_form_inherit2" model="ir.ui.view">
    <field name="name">training.course.form.inherit</field>
    <field name="model">hmv.training.plan</field>
    <field name="inherit_id" ref="hino_training.view_training_plan_form"/>
    <field name="arch" type="xml">
        <!-- Chèn tab mới vào trong notebook -->
        <xpath expr="//form/sheet/notebook" position="inside">
            <page string="Training courses provided by company">
                <field name="tab_training_courses_id">
                    <tree editable="bottom" create="false">
                        <field name="course_title"/>
                        <field name="vendor_id"/>
                        <field name="location_id"/>
                        <field name="slot"/>
                        <field name="recommend_level_ids" widget="many2many_tags"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="course_type"/>
                   <field name="fee" readonly="course_type == 'in_house'" />
<field name="estimated_fee" readonly="course_type == 'public'" />
                        <field name="other_fee"/>   
                        <field name="participant_ids"/>
                    </tree>
                </field>
                <!-- Chèn group hiển thị tổng vào bên trong tab -->
                    <group string="Totals" colspan="4" style="float: right; margin-top: 10px;">
                    <!-- Nhóm 1: Hiển thị total_estimated_fee và total_other_fee trên 1 dòng -->
                    <group col="2">
                        <field name="total_estimated_fee" readonly="1" widget="monetary"/>
                        <field name="total_other_fee" readonly="1" widget="monetary"/>
                    </group>
                    <!-- Nhóm 2: Hiển thị total_fee dưới dòng trên -->
                    <group style= "text-align:center;">
                        <field name="total_fee" readonly="1" widget="monetary"/>
                    </group>
                </group>

            </page>
        </xpath>
    </field>
</record>



