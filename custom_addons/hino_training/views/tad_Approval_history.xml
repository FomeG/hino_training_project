<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <!-- Inherit view_training_plan_form -->
        <record id="view_tab_aprroval_history_inherit2_tab_approval" model="ir.ui.view">
            <field name="name">training.course.form.inherit.tab.approval</field>
            <field name="model">hmv.training.plan</field>
            <field name="inherit_id" ref="hino_training.view_training_plan_form"/>
            <field name="arch" type="xml">
                <!-- Chèn tab mới vào trong notebook -->
            <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Approval history" name="tab_approval_history">
                        <group>
                            <field name="training_course_ids">
                                <tree editable="bottom">
                                    <field name="course_title"/>
                                    <field name="vendor_id"/>
                                    <field name="location_id"/>
                                    <field name="slot"/>
                                    <field name="recommend_level_ids"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="course_type"/>
                                    <field name="fee"/>
                                    <field name="estimated_fee"/>
                                    <field name="other_fee"/>
                                    <field name="participant_ids"/>
                                    <field name="department_id"/>
                                    <field name="purchase_order_id"/>
                                    <field name="department_id"/>
                                    <field name="location_id"/>
                                    <field name="department_id"/>
                                    <field name="currency_id"/>


                                    <field name="training_content"/>
                                    <field name="confirmation_start_date"/>
                                    <field name="confirmation_end_date"/>
                                    <field name="year"/>


                                    <field name="description"/>
                                    <field name="status"/>
                                    <field name="department_id"/>
                                    <field name="currency_id"/>  
                                    <field name="department_id"/>
                                    <field name="currency_id"/>



                                </tree>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>

</odoo>
