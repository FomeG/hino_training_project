<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_training_need_tree" model="ir.ui.view">
        <field name="name">hmv.training.need.tree</field>
        <field name="model">hmv.training.need</field>
        <field name="arch" type="xml">
            <tree string="Training Needs" decoration-info="state == 'draft'"
                decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"
                sample="1">

                <header>
                    <button name="action_send_mass_email"
                        string="Send Mass Email"
                        type="object"
                        class="btn-primary" />
                </header>


                <field name="name" />
                <field name="employee_id" />
                <field name="assignee_id" />
                <field name="department_id" />
                <field name="registration_date" />
                <field name="training_brochure_id" />
                <field name="company_id" optional="hide" />
                <field name="state" widget="badge" decoration-success="state == 'approved'"
                    decoration-info="state == 'draft'" decoration-danger="state == 'rejected'" />
                <!-- <field name="description" optional="show" /> -->
            </tree>
        </field>
    </record>


    <!-- form view mới với chatter -->
    <record id="view_training_need_form" model="ir.ui.view">
        <field name="name">hmv.training.need.form</field>
        <field name="model">hmv.training.need</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button name="action_submit"
                        string="Submit"
                        type="object"
                        class="oe_highlight"
                        invisible="state not in ('draft', 'rejected')" />


                    <!-- Manager -> Senior Manager -> DGM -> GM -> Officer -> HR manager -->

                    <button name="action_manager_approve"
                        string="Manager Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'submitted'" />

                    <button name="action_senior_manager_approve"
                        string="Senior Manager Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'manager_approved'" />

                    <button name="action_dgm_approve"
                        string="DGM Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'senior_manager_approved'" />

                    <button name="action_gm_approve"
                        string="GM Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'dgm_approved'" />

                    <button name="action_officer_approve"
                        string="Officer Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'gm_approved'" />

                    <button name="action_hr_manager_approve"
                        string="HR Manager Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'officer_approved'" />

                    <!-- =========================================================== -->


                    <button name="action_reject"
                        string="Reject"
                        type="object"
                        class="btn-danger"
                        invisible="state in ['draft','completed','rejected']" />

                    <button name="action_send_email"
                        string="Send Email"
                        type="object"
                        class="btn-primary" />


                    <field name="state" widget="statusbar" />


                </header>
                <sheet>
                    <h3>Training Need No.</h3>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="description" />
                            <field name="employee_id" />
                            <field name="assignee_id" />
                            <field name="department_id" />
                        </group>
                        <group>
                            <field name="company_id" />
                            <field name="registration_date" />
                            <field name="training_brochure_id" />
                        </group>
                    </group>
                    <notebook>


                        <!-- Tab Company Training -->
                        <page string="Training courses provided by company" name="company_training">
                            <field name="company_line_ids">
                                <tree editable="bottom">
                                    <field name="employee_id" />
                                    <field name="email" />
                                    <field name="training_brochure_line_id" widget="many2many_tags" />
                                </tree>
                            </field>
                        </page>


                        <!-- Tab Factory Training -->
                        <page string="Factory Training" name="factory_training">
                            <field name="factory_line_ids">
                                <tree editable="bottom">
                                    <field name="employee_id" />
                                    <field name="email" />
                                    <field name="training_brochure_line_id" widget="many2many_tags"/>
                                </tree>
                            </field>
                        </page>


                        <!-- Tab Other Training -->
                        <page string="Other Training" name="other_training">
                            <field name="other_line_ids">
                                <tree editable="bottom">
                                    <field name="employee_id" />
                                    <field name="email" />
                                    <field name="training_brochure_line_id" widget="many2many_tags"/>
                                </tree>
                            </field>
                        </page>


                        <!-- Tab Approval History -->
                        <page string="Approval History" name="approval_history">
                            <field name="approval_line_ids">
                                <tree>
                                    <field name="employee_id" />
                                    <field name="job_id" />
                                    <field name="department_id" />
                                    <field name="status" widget="badge" />
                                    <field name="comment" />
                                </tree>
                            </field>
                        </page>


                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="action_training_need_view" model="ir.actions.act_window">
        <field name="name">Training Need</field>
        <field name="res_model">hmv.training.need</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>